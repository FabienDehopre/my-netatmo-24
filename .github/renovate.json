{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:allNonMajor",
    "helpers:disableTypesNodeMajor",
    "schedule:automergeDaily",
    ":automergeStableNonMajor",
    ":semanticCommitType(build)",
    ":semanticCommitScopeDisabled",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/Brussels",
  "prConcurrentLimit": 1,
  "automergeType": "pr",
  "automergeStrategy": "squash",
  "major": {
    "dependencyDashboardApproval": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Skip release age delay for own packages",
      "matchPackageNames": ["@fabdeh/{/,}**"],
      "minimumReleaseAge": "0 days"
    },
    {
      "description": "Disable updates for TypeScript",
      "matchPackageNames": [
        "typescript"
      ],
      "enabled": false
    },
    {
      "description": "Microsoft.OpenApi 3.x requires ASP.NET Core 11 (Microsoft.AspNetCore.OpenApi source generator breaks); stay on 2.x until the app targets .NET 11",
      "matchPackageNames": ["Microsoft.OpenApi"],
      "allowedVersions": "<3.0.0"
    }
  ],
  "ignorePaths": [
    "**/.agents/**"
  ],
  "nuget": {
    "ignorePaths": [
      "**/.agents/**",
      "**/node_modules/**",
      "**/bower_components/**",
      "**/vendor/**",
      "**/examples/**",
      "**/__fixtures__/**"
    ]
  }
}
